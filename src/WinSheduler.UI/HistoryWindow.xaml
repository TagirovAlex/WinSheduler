<Window x:Class="WinSheduler.UI.HistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Журнал запусков" Height="400" Width="700"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="TitleText" Grid.Row="0" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>

        <ListView x:Name="HistoryList" Grid.Row="1">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Начало" DisplayMemberBinding="{Binding StartTime}" Width="120"/>
                    <GridViewColumn Header="Конец" DisplayMemberBinding="{Binding EndTime}" Width="120"/>
                    <GridViewColumn Header="Статус" DisplayMemberBinding="{Binding Status}" Width="100"/>
                    <GridViewColumn Header="Код" DisplayMemberBinding="{Binding ExitCode}" Width="60"/>
                    <GridViewColumn Header="Ошибка" DisplayMemberBinding="{Binding ErrorMessage}" Width="250"/>
                </GridView>
            </ListView.View>
        </ListView>
    </Grid>
</Window>
