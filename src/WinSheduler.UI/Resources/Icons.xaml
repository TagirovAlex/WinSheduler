<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Иконки как BitmapImage из ресурсов -->
    <!-- Формат pack URI: ;component = сборка по умолчанию -->
    <BitmapImage x:Key="IconRefresh" UriSource="pack://application:,,,/;component/Resources/Icons/refresh.png"/>
    <BitmapImage x:Key="IconAdd" UriSource="pack://application:,,,/;component/Resources/Icons/add.png"/>
    <BitmapImage x:Key="IconEdit" UriSource="pack://application:,,,/;component/Resources/Icons/edit.png"/>
    <BitmapImage x:Key="IconDelete" UriSource="pack://application:,,,/;component/Resources/Icons/delete.png"/>
    <BitmapImage x:Key="IconHistory" UriSource="pack://application:,,,/;component/Resources/Icons/history.png"/>
    <BitmapImage x:Key="IconBrowse" UriSource="pack://application:,,,/;component/Resources/Icons/folder.png"/>
    <BitmapImage x:Key="IconSave" UriSource="pack://application:,,,/;component/Resources/Icons/save.png"/>
    <BitmapImage x:Key="IconCancel" UriSource="pack://application:,,,/;component/Resources/Icons/cancel.png"/>
    <BitmapImage x:Key="IconOk" UriSource="pack://application:,,,/;component/Resources/Icons/ok.png"/>
    <BitmapImage x:Key="IconTrigger" UriSource="pack://application:,,,/;component/Resources/Icons/trigger.png"/>
    <BitmapImage x:Key="IconStart" UriSource="pack://application:,,,/;component/Resources/Icons/start.png"/>

</ResourceDictionary>
