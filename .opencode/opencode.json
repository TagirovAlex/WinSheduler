{
  "$schema": "https://opencode.ai/config.json",
  "skills": {
    "paths": ["skills"]
  },
  "mcp": {
    "filesystem": {
      "type": "local",
      "command": [
        "node",
        "C:/Github/mcpservers/node_modules/@modelcontextprotocol/server-filesystem/dist/index.js",
        "C:/Github/WinSheduler"
      ],
      "enabled": true
    },
    "memory": {
      "type": "local",
      "command": [
        "node",
        "C:/Github/mcpservers/node_modules/@modelcontextprotocol/server-memory/dist/index.js"
      ],
      "enabled": true,
      "env": {
        "MEMORY_FILE_PATH": "C:/Github/WinSheduler/.memory.jsonl"
      }
    },
    "sequential-thinking": {
      "type": "local",
      "command": [
        "node",
        "C:/Github/mcpservers/node_modules/@modelcontextprotocol/server-sequential-thinking/dist/index.js"
      ],
      "enabled": true
    },
    "context7": {
      "type": "local",
      "command": [
        "node",
        "C:/Github/mcpservers/node_modules/@upstash/context7-mcp/dist/index.js"
      ],
      "enabled": true
    }
  },
  "experimental": {
    "primary_tools": ["read", "write", "edit", "glob", "grep"]
  }
}
